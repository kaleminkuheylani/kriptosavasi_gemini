// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String                   // Görünen ad
  investorType    String                   // 'short' | 'long' | 'both'
  heardFrom       String                   // 'social_media' | 'friend' | 'google' | 'youtube' | 'other'
  avatar          String   @default("cyan")
  dailyRequests   Int      @default(0)
  lastRequestDate String?                  // YYYY-MM-DD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  watchlist    WatchlistItem[]
  alerts       PriceAlert[]
}

model WatchlistItem {
  id          String   @id @default(cuid())
  symbol      String   // Hisse kodu (ASELS, THYAO, vb.)
  name        String   // Hisse adı
  targetPrice Float?   // Hedef fiyat (bildirim için)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceAlert {
  id          String   @id @default(cuid())
  symbol      String
  targetPrice Float
  condition   String   // "above" veya "below"
  active      Boolean  @default(true)
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
